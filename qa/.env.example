# =============================================================================
# Fixtronix ERP — QA / Playwright harness environment template.
# Copy to `.env` and adjust if your stack isn't on the default localhost ports.
# All keys are OPTIONAL — they default to the local dev stack.
# =============================================================================

# Backend GraphQL base (the suite hits {API_URL}/graphql). Default localhost:3000.
API_URL=http://localhost:3000

# Frontend base URL for the UI specs. Default localhost:4200.
UI_URL=http://localhost:4200

# Mongo used for deterministic test-data staging/cleanup (utils/mongo.ts).
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB=fixtronix

# Optional: skip the live login and reuse a JWT for API specs. Empty = the
# helpers fall back to the seeded .auth storageState, then a live login.
TEST_TOKEN=
