# =============================================================================
# Dependencies
# =============================================================================
/node_modules
qa/node_modules
jspm_packages/
.pnp.*

# =============================================================================
# Build / output
# =============================================================================
/dist
/build
/tmp

# =============================================================================
# TypeScript incremental build info
# =============================================================================
*.tsbuildinfo

# =============================================================================
# Logs
# =============================================================================
*.log
logs/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# =============================================================================
# Cache
# =============================================================================
.eslintcache
.stylelintcache
/.cache/

# =============================================================================
# Coverage / test artifacts
# =============================================================================
/coverage
/.nyc_output

# =============================================================================
# Environment files — NEVER commit secrets. Templates (.env.example /
# .env.template) ARE committed; real .env files are not.
# =============================================================================
.env
.env.*
!.env.example
!.env.template

# =============================================================================
# QA audit logs — generated, machine-local, never tracked
# =============================================================================
_audit_logs/

# =============================================================================
# Uploads / runtime documents
# `docs/` is the NestJS static-serve root for user-uploaded files
# (see ServeStaticModule in src/app.module.ts). Keep the folder, ignore contents.
# =============================================================================
/docs/*
!/docs/.gitkeep

# =============================================================================
# Versioned context + QA suite (vendored so a clone has everything ready).
# `.project-context` is a dotfolder — keep it tracked explicitly.
# =============================================================================
!.project-context/

# =============================================================================
# IDE / Editor — JetBrains
# =============================================================================
/.idea/
*.iml

# =============================================================================
# IDE / Editor — VSCode / history (machine-specific; do not share)
# =============================================================================
.vscode/
.history/

# =============================================================================
# IDE / Editor — Eclipse / Sublime / Cloud9
# =============================================================================
.project
.classpath
.settings/
.c9/
*.launch
*.sublime-workspace

# =============================================================================
# OS files
# =============================================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# =============================================================================
# Editor swap / backup files
# =============================================================================
*.swp
*.swo
*~
*.bak
*.orig
