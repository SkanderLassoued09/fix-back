# =============================================================================
# Dependencies
# =============================================================================
/node_modules
jspm_packages/
.pnp.*

# =============================================================================
# Build / output
# =============================================================================
/dist
/build
/tmp

# =============================================================================
# TypeScript incremental build info
# =============================================================================
*.tsbuildinfo

# =============================================================================
# Logs
# =============================================================================
*.log
logs/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# =============================================================================
# Cache
# =============================================================================
.eslintcache
.stylelintcache
/.cache/

# =============================================================================
# Coverage / test artifacts
# =============================================================================
/coverage
/.nyc_output

# =============================================================================
# Environment files
# (NEVER commit secrets — pin a `.env.example` if you need a template)
# =============================================================================
.env
.env.*
!.env.example

# =============================================================================
# Uploads / runtime documents
# `docs/` is the NestJS static-serve root for user-uploaded files
# (see ServeStaticModule in src/app.module.ts). The folder itself
# must exist at runtime, so a `.gitkeep` is committed and everything
# else inside is ignored.
# =============================================================================
/docs/*
!/docs/.gitkeep

# =============================================================================
# IDE / Editor — JetBrains
# =============================================================================
/.idea/
*.iml

# =============================================================================
# IDE / Editor — VSCode (machine-specific; do not share)
# =============================================================================
.vscode/
.history/

# =============================================================================
# IDE / Editor — Eclipse / Sublime / Cloud9
# =============================================================================
.project
.classpath
.settings/
.c9/
*.launch
*.sublime-workspace

# =============================================================================
# OS files
# =============================================================================
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# =============================================================================
# Editor swap / backup files
# =============================================================================
*.swp
*.swo
*~
*.bak
*.orig
