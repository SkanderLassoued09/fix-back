# ───────────────────────────────────────────────────────────────────────────
# Fixtronix backend (NestJS) — environment template.
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# Loaded by `import 'dotenv/config'` in src/main.ts (does NOT override vars
# already present in the process environment).
# ───────────────────────────────────────────────────────────────────────────

# ── Core / runtime ─────────────────────────────────────────────────────────
NODE_ENV="development"                       # development | production
PORT="3000"                                  # HTTP/GraphQL port
MONGODB_URI="mongodb://localhost:27017/fixtronix"   # Mongo connection string
CORS_ORIGIN=""                               # comma-separated allow-list; empty = any (dev)
BODY_LIMIT="5gb"                             # max request body size
GRAPHQL_PLAYGROUND="true"                    # "false" to disable in prod

# ── Discord — critical operational alerts ──────────────────────────────────
# Webhook for the OperationalErrorService critical channel (errors/outages).
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/XXXXX/YYYYY"

# ── Discord — "validation" channel (dev drift watch; SEPARATE from critical) ─
DISCORD_VALIDATION_WEBHOOK_URL="https://discord.com/api/webhooks/XXXXX/YYYYY"
DISCORD_NOTIFY_VALIDATION="false"            # true only in dev to surface validation drift
DISCORD_VALIDATION_DEDUP_MS="600000"         # per-key dedup window (ms) — 10 min
DISCORD_VALIDATION_CAP_PER_HOUR="20"         # global hourly cap; excess aggregated

# ── Google Sheets (daily export) ───────────────────────────────────────────
GOOGLE_SHEETS_ID="your-google-sheet-id"
GOOGLE_SHEETS_TAB="Sheet1"
# Optional extra tab used by the stats mapper:
# GOOGLE_SHEETS_STATS_TAB="Stats"

# ── Google service account (shared by Sheets + Drive) ──────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL="service-account@your-project.iam.gserviceaccount.com"
# Single line; encode newlines as the literal \n sequence.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"

# ── Google Drive (auto client folder on company creation) ──────────────────
# Prereq: enable the Drive API in the same GCP project as Sheets, create a
# Shared Drive, add the service account as Content manager. Leave PARENT empty
# to disable Drive (company creation still works; driveFolderId stays null).
GOOGLE_DRIVE_PARENT_FOLDER_ID=""             # parent "Clients" folder id (Shared Drive)
GOOGLE_DRIVE_ID=""                           # Shared Drive id (informational)
DRIVE_FOLDER_DATE_FORMAT="DD/MM/YYYY HH:mm:ss"  # or "YYYY-MM-DD_HH-mm-ss" for desktop sync
APP_TIMEZONE="Africa/Tunis"                  # timezone for the folder-name timestamp

# ───────────────────────────────────────────────────────────────────────────
# Frontend (Angular) note: the app does NOT read this .env at runtime — its
# config lives in fix-front/src/environments/environment.ts (build-time):
#   apiUrl : http://localhost:3000/   (must match PORT above; drives GraphQL
#            HTTP + WebSocket subscriptions)
#   host   : http://localhost:4200/
# Keep environment.ts's apiUrl port in sync with PORT.
# ───────────────────────────────────────────────────────────────────────────
