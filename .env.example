# =============================================================================
# Fixtronix ERP — backend (fix-back) environment template.
# Copy to `.env` and fill in values:  cp .env.example .env
# The real `.env` is gitignored — NEVER commit secrets.
#
# Every key below is read by the code. All have safe fallbacks or degrade
# gracefully, so the API BOOTS with an empty/partial .env; the comments say what
# each enables. The only thing strictly needed to run the app + tests is a
# reachable MongoDB (MONGODB_URI).
# =============================================================================

# ── Core / runtime ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
# Mongo connection string. REQUIRED for anything useful (defaults to localhost).
MONGODB_URI=mongodb://localhost:27017/fixtronix
# CORS allow-list (comma-separated). Empty = reflect the request origin (dev).
CORS_ORIGIN=
# Max request body size (Express/bodyParser).
BODY_LIMIT=5gb
# Expose the GraphQL playground. Set "false" in production.
GRAPHQL_PLAYGROUND=true

# ── Discord alerts (OPTIONAL — left empty = no Discord calls) ────────────────
# Critical operational-error webhook.
DISCORD_WEBHOOK_URL=
# Separate dev-only "validation drift" channel.
DISCORD_VALIDATION_WEBHOOK_URL=
# Enable the validation channel (only fires when NODE_ENV != production).
DISCORD_NOTIFY_VALIDATION=false
DISCORD_VALIDATION_DEDUP_MS=600000
DISCORD_VALIDATION_CAP_PER_HOUR=20

# ── Google Sheets export (OPTIONAL — empty = export disabled, logged not fatal)
# Sheets STILL uses the service account (it only EDITS a pre-existing,
# human-owned spreadsheet → no storage quota needed).
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_TAB=Sheet1
GOOGLE_SHEETS_STATS_TAB=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Service-account PEM. Keep the literal \n escapes on one line, quoted.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── Google Drive uploads — OAuth 2.0 (OPTIONAL; empty = upload disabled) ──────
# Drive uses OAuth as a REAL account (the one with the storage quota), NOT the
# service account (a SA has no quota → storageQuotaExceeded). Create an OAuth
# "Web application" client in the SAME GCP project, add the redirect URI below
# to it, then run the one-time consent flow:
#   1. open  http://localhost:3000/auth/google  (sign in with the quota account)
#   2. the callback prints a refresh token → paste it below
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback
GOOGLE_OAUTH_REFRESH_TOKEN=
# Parent "CLIENTS" folder id IN THE DRIVE OF THE QUOTA-OWNING ACCOUNT.
GOOGLE_DRIVE_PARENT_FOLDER_ID=
# Optional: Shared Drive id (only if the parent lives in a Workspace Shared Drive).
GOOGLE_DRIVE_ID=
# "DD/MM/YYYY HH:mm:ss" by default; use "YYYY-MM-DD_HH-mm-ss" if Drive desktop
# sync is used (/, : are illegal in filenames on Windows/macOS).
DRIVE_FOLDER_DATE_FORMAT=DD/MM/YYYY HH:mm:ss
APP_TIMEZONE=Africa/Tunis

# ── Cron / action dispatcher (OPTIONAL) ──────────────────────────────────────
# Set to run a one-off action instead of the HTTP server (e.g. DETECT_STAGNANT_DI).
# ACTION=

# NOTE: the JWT signing secret is currently HARDCODED in src/auth (not read
# from env). Out of scope here; flagged for a future security pass.
